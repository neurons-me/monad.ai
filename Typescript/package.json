{
  "name": "monad.ai",
  "version": "2.2.1",
  "description": "Monad daemon for identity, ledger, and semantic runtime surfaces.",
  "author": "suiGn",
  "license": "ISC",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "monad.ai": "./dist/src/cli/monads.js",
    "monads": "./dist/src/cli/monads.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "prebuild": "npm run test:netget",
    "dev": "tsx watch server.ts",
    "build": "tsc && node --input-type=commonjs -e \"require('fs').writeFileSync('dist/package.json', JSON.stringify({ type: 'module' }, null, 2) + '\\n')\"",
    "start": "tsx server.ts",
    "test": "vitest run",
    "test:netget": "vitest run tests/netgetRegistration.test.ts",
    "test:claims": "tsx tests/claim_test_verification.ts",
    "init:public-figures": "tsx tests/inits/public_figures/index.ts",
    "lint": "eslint . --ext .ts",
    "runBuild": "npm run build && npm run start",
    "docs:api": "typedoc",
    "docs:api:watch": "typedoc --watch",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:publish": "npm run docs:api && npm run docs:build && mkdir -p typedocs && touch typedocs/.nojekyll"
  },
  "dependencies": {
    "cleaker": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "this.me": "workspace:*"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.1",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.20.6",
    "typedoc": "^0.28.16",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.5"
  }
}
