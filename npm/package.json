{
  "name": "monad.ai",
  "version": "2.1.1",
  "description": "Monad daemon for identity, ledger, and semantic runtime surfaces.",
  "author": "suiGn",
  "license": "ISC",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc && node --input-type=commonjs -e \"require('fs').writeFileSync('dist/package.json', JSON.stringify({ type: 'commonjs' }, null, 2) + '\\n')\"",
    "start": "tsx server.ts",
    "test": "jest --runInBand --colors",
    "test:claims": "tsx tests/claim_test_verification.ts",
    "init:public-figures": "tsx tests/inits/public_figures/index.ts",
    "lint": "eslint . --ext .ts",
    "runBuild": "npm run build && npm run start",
    "docs:api": "typedoc --entryPoints ./server.ts --out docs/api --plugin typedoc-plugin-markdown --readme none --excludePrivate --excludeInternal",
    "docs:api:watch": "typedoc --watch --entryPoints ./server.ts --out docs/api --plugin typedoc-plugin-markdown --readme none --excludePrivate --excludeInternal",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:publish": "npm run docs:build && touch docs/.vitepress/dist/.nojekyll"
  },
  "dependencies": {
    "cleaker": "file:../../cleaker/npm",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "this.me": "file:../../../this/.me/npm"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.1",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.20.6",
    "typedoc": "^0.28.16",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4"
  }
}
